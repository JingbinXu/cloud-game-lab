[Unit]
Description=Resume MVP Backend (FastAPI)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/resume-mvp/resume-mvp/backend
EnvironmentFile=/home/ubuntu/resume-mvp/resume-mvp/backend/.env
ExecStart=/home/ubuntu/resume-mvp/resume-mvp/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
